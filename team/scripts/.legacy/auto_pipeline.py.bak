#!/usr/bin/env python3 """ Auto Pipeline - Claude Agent SDK based Python implementation replacing auto-pipeline.sh shell script """ import os import json import re import subprocess from datetime import datetime from pathlib import Path from anthropic import Anthropic class AutoPipeline: def __init__(self, project_path: str): self.project_path = Path(project_path) self.workspace_root = self.project_path.parent.parent self.progress_file = self.project_path / ".pipeline-progress.json" self.sessions_dir = self.project_path / ".sessions" # Anthropic API client self.client = Anthropic() # Auto-response rules (load from JSON) self.auto_responses = self._load_auto_responses() def _load_auto_responses(self) -> dict: """Load auto-responses.json file""" config_path = self.workspace_root / ".config" / "auto-responses.json" if not config_path.exists(): print(f"⚠️ auto-responses.jsonnot found: {config_path}") print(" basic response ruleswill be used.") # Fallback to hardcoded responses return {"fallback": {"default_response": "Please proceed with the current plan." } } try: with open(config_path, 'r', encoding='utf-8') as f: return json.load(f) except Exception as e: print(f"⚠️ auto-responses.json load failed: {e}") print(" basic response ruleswill be used.") return {"fallback": {"default_response": "Please proceed with the current plan." } } def load_agent_prompt(self, agent_name: str) -> str: """agent CLAUDE.md load""" claude_md = self.workspace_root / f".agents/{agent_name}/CLAUDE.md" with open(claude_md, 'r') as f: return f.read() def load_progress(self) -> dict: """in progressstatus load""" if self.progress_file.exists(): with open(self.progress_file, 'r') as f: return json.load(f) return {} def save_progress(self, ticket_num: str, step: str): """in progressstatus save""" progress = {"last_ticket": ticket_num, "last_step": step, "timestamp": datetime.utcnow().isoformat() + "Z", "auto_push": True } with open(self.progress_file, 'w') as f: json.dump(progress, f, indent=2) def run_agent(self, agent_name: str, user_prompt: str, ticket_num: str = None) -> dict: """ Execute agent (core feature) Args: agent_name: pm, coding, qa 등 user_prompt: agentto게 전달할 prompt ticket_num: ticket number (for session saving) Returns: result dictionary """ # agent when스템 prompt load system_prompt = self.load_agent_prompt(agent_name) # session ID generate import uuid session_id = str(uuid.uuid4()) print(f"🤖 {agent_name.upper()} Agent execute in progress...") print(f"📋 prompt: {user_prompt[:100]}...") # conversation history messages = [{"role": "user", "content": user_prompt}] # auto response 루프 max_turns = 10 # prevent infinite loop turn = 0 while turn < max_turns: turn += 1 # Claude API call response = self.client.messages.create(model="claude-sonnet-4-5-20241022", max_tokens=8000, system=system_prompt, messages=messages) # process response assistant_message = response.content[0].text print(f"\n{'='*60}") print(f"Claude (Turn {turn}):") print(assistant_message) print('='*60) # conversation historyto add messages.append({"role": "assistant", "content": assistant_message }) # check exit condition if response.stop_reason == "end_turn": print("✅ agent task completed") break # auto response 체크 auto_response = self._check_auto_response(assistant_message, agent_name) if auto_response: print(f"\n[AUTO-RESPONSE] {auto_response}") messages.append({"role": "user", "content": auto_response }) else: # question 있지만 auto response rules 없 경우 print("\n⚠️ 알 수 없 question - fallback responseto in progress") fallback_response = self.auto_responses.get("fallback", {}).get("default_response", "Please proceed with the current plan.") messages.append({"role": "user", "content": fallback_response }) # session save if ticket_num: self._save_session(ticket_num, agent_name, session_id, messages) return {"success": True, "session_id": session_id, "messages": messages } def _check_auto_response(self, message: str, agent_name: str = "global") -> str: """messagein question detect and auto response return (Regex support)""" # 1. agent별 rules 체크 agent_patterns = self.auto_responses.get(agent_name, {}).get("patterns", []) for rule in agent_patterns: try: if re.search(rule["trigger"], message, re.IGNORECASE): print(f" [matched rules: {rule['id']}]") if "gotcha_ref" in rule: print(f" [reference: {rule['gotcha_ref']}]") return rule["response"] except re.error as e: print(f"⚠️ Regex error ({rule['id']}): {e}") continue # 2. Global rules 체크 global_patterns = self.auto_responses.get("global", {}).get("patterns", []) for rule in global_patterns: try: if re.search(rule["trigger"], message, re.IGNORECASE): print(f" [matched rules: global/{rule['id']}]") return rule["response"] except re.error as e: print(f"⚠️ Regex error (global/{rule['id']}): {e}") continue # 3. Fallback fallback = self.auto_responses.get("fallback", {}) return fallback.get("default_response", None) def _save_session(self, ticket_num: str, agent_name: str, session_id: str, messages: list): """Save session information""" self.sessions_dir.mkdir(exist_ok=True) ticket_dir = self.sessions_dir / ticket_num ticket_dir.mkdir(exist_ok=True) # session map update session_map_file = self.sessions_dir / "session-map.json" session_map = {} if session_map_file.exists(): with open(session_map_file, 'r') as f: session_map = json.load(f) if ticket_num not in session_map: session_map[ticket_num] = {} session_map[ticket_num][agent_name] = {"session_id": session_id, "timestamp": datetime.utcnow().isoformat() + "Z", "status": "completed", "message_count": len(messages) } with open(session_map_file, 'w') as f: json.dump(session_map, f, indent=2) # save individual session file session_file = ticket_dir / f"{agent_name}.json" with open(session_file, 'w') as f: json.dump({"session_id": session_id, "messages": messages }, f, indent=2) def run_full_pipeline(self, resume: bool = False): """whole pipeline execute""" tickets_dir = self.project_path / "planning/tickets" ticket_files = sorted(tickets_dir.glob("PLAN-*.md")) print(f"\n{'='*60}") print(f"🚀 Auto Pipeline start") print(f"📂 project: {self.project_path.name}") print(f"📋 total ticket: {len(ticket_files)}items") print('='*60) # in progressstatus load progress = self.load_progress() if resume else {} resume_from_ticket = progress.get("last_ticket", "") resume_from_step = progress.get("last_step", "") for ticket_file in ticket_files: ticket_num = ticket_file.stem.split('-')[0] + '-' + ticket_file.stem.split('-')[1] ticket_name = ticket_file.name # Resume mode: already completed한 ticket skip if resume_from_ticket: if ticket_num < resume_from_ticket: print(f"⏭️ skip: {ticket_name} (already completed)") continue elif ticket_num == resume_from_ticket: print(f"📍 resume: {ticket_name} ({resume_from_step} completed, next stagefrom)") # next stagefrom start start_step = self._next_step(resume_from_step) else: start_step = "pm" else: start_step = "pm" print(f"\n{'='*60}") print(f"📋 ticket: {ticket_name}") print('='*60) # ticket content read with open(ticket_file, 'r') as f: ticket_content = f.read() try: # Step 1: PM Agent if start_step in ["pm", "coding", "qa"]: result = self.run_agent("pm", ticket_content, ticket_num) self.save_progress(ticket_num, "pm") # Step 1.5: Validate-Spec Skill print(f"\n🔍 specification verification in progress...") validation_result = self._run_validate_spec(ticket_num, auto_fix=True) if not validation_result["passed"]: print(f"\n⚠️ specification verification failed - re-execute PM Agent") # verification issue promptto 포함하여 재execute retry_prompt = self._build_retry_prompt(ticket_content, validation_result) result = self.run_agent("pm", retry_prompt, ticket_num) # re-verification validation_retry = self._run_validate_spec(ticket_num, auto_fix=True) if not validation_retry["passed"]: raise Exception("specification re-verification failed - manual intervention required") print(f"\n✅ specification re-verification passed") else: print(f"\n✅ specification verification passed") # Step 2: Coding Agent if start_step in ["coding", "qa"]: coding_prompt = f"{ticket_num} ticket implementing." result = self.run_agent("coding", coding_prompt, ticket_num) self.save_progress(ticket_num, "coding") # Step 2.5: Refactor-Code Skill (select) print(f"\n🔧 code refactoring suggestion check in progress...") refactor_result = self._run_refactor_code(ticket_num) if refactor_result and refactor_result.get("auto_fixable_count", 0) > 0: print(f"💡 {refactor_result['auto_fixable_count']}items auto fix possible issue found") # auto fix manualto execute하도록 안내 print(" (auto fix: bash scripts/run-skill.sh refactor-code --auto-fix)") # Step 3: QA Agent if start_step == "qa": qa_prompt = f"{ticket_num} ticketof test write합니다." result = self.run_agent("qa", qa_prompt, ticket_num) self.save_progress(ticket_num, "qa") # Step 3.5: Test-Runner Skill (required) print(f"\n🧪 test execute in progress...") test_result = self._run_test_runner() if test_result: if test_result.get("all_passed"): print(f"✅ all test passed: {test_result.get('passed')}/{test_result.get('total')}") print(f"📊 coverage: {test_result.get('coverage', 0)*100:.1f}%") else: print(f"❌ tests failed: {test_result.get('failed')}items") print(" QA Agent 재execute required") raise Exception("tests failed - manual intervention required") # Step 4: Commit Skill print(f"\n💾 commit message generate in progress...") commit_result = self._run_commit_skill(ticket_num) if commit_result and commit_result.get("success"): print(f"✅ commit completed: {commit_result.get('commit_hash', 'N/A')}") else: print("⚠️ commit skill execute failed - manual commit required") # Step 5: Docs-Generator Skill (API change when) if self._has_api_changes(): print(f"\n📝 API documentation generate in progress...") docs_result = self._run_docs_generator() if docs_result and docs_result.get("success"): print(f"✅ documentation generate completed") # documentation change사항 commit self._commit_docs(ticket_num) # Step 5: Git Push (select) # self._git_push(ticket_num) print(f"\n✅ {ticket_name} completed!") except Exception as e: print(f"\n❌ {ticket_name} failed: {e}") self.save_progress(ticket_num, start_step) raise # completed after in progressstatus file delete if self.progress_file.exists(): self.progress_file.unlink() print(f"\n{'='*60}") print("🎉 whole pipeline completed!") print('='*60) def _next_step(self, current_step: str) -> str: """current stage next stage return""" steps = {"pm": "coding", "coding": "qa", "qa": "commit"} return steps.get(current_step, "pm") def _run_validate_spec(self, ticket_num: str, auto_fix: bool = False) -> dict: """ validate-spec skill execute Returns: {"passed": bool, "errors": [], "warnings": [], "auto_fixes": []} """ # validate.py 스크립트 route validate_script = self.workspace_root / ".skills/validate-spec/validate.py" if not validate_script.exists(): print(f"⚠️ validate-spec skillnot found: {validate_script}") return {"passed": True, "errors": [], "warnings": [], "auto_fixes": []} # skill execute cmd = ["python3", str(validate_script), ticket_num] if auto_fix: cmd.append("--auto-fix") # project directoryin execute result = subprocess.run(cmd, cwd=self.project_path, capture_output=True, text=True) # parse result output = result.stdout # Exit codeto passed 판정 passed = (result.returncode == 0) # extract errors/warnings (simple parsing) errors = [] warnings = [] auto_fixes = [] for line in output.split('\n'): if line.startswith("1. [") or line.startswith("2. [") or line.startswith("3. ["): if "[completeness]" in line or "[range]" in line or "[quality]" in line: if "❌" in output: # error section errors.append(line) elif "⚠️" in output: # warning section warnings.append(line) elif line.startswith("✓"): auto_fixes.append(line) return {"passed": passed, "errors": errors, "warnings": warnings, "auto_fixes": auto_fixes, "output": output } def _build_retry_prompt(self, original_ticket: str, validation_result: dict) -> str: """verification failed when 재execute prompt generate""" issues = [] if validation_result["errors"]: issues.append("**error**:") for err in validation_result["errors"]: issues.append(f"- {err}") if validation_result["warnings"]: issues.append("\n**warning**:") for warn in validation_result["warnings"]: issues.append(f"- {warn}") issues_text = "\n".join(issues) retry_prompt = f"""previous specificationto next issue found되었습니다: {issues_text} up issue fix하여 specification 재generateplease proceed. --- original ticket --- {original_ticket} """ return retry_prompt def _run_refactor_code(self, ticket_num: str) -> dict: """ refactor-code skill execute Returns: {"issues_found": int, "auto_fixable_count": int, "suggestions": []} """ refactor_script = self.workspace_root / ".skills/refactor-code/refactor-code.py" if not refactor_script.exists(): return None # list of changed files result = subprocess.run(["git", "diff", "--name-only", "HEAD"], cwd=self.project_path, capture_output=True, text=True) changed_files = [f.strip() for f in result.stdout.split('\n') if f.strip()] if not changed_files: return None # each fileto 대해 refactoring suggestion execute total_issues = 0 auto_fixable = 0 for file in changed_files: file_path = self.project_path / file if not file_path.exists() or not file_path.suffix in ['.js', '.ts', '.py', '.go']: continue result = subprocess.run(["python3", str(refactor_script), "--file", str(file_path)], cwd=self.project_path, capture_output=True, text=True) # simple parsing (실제to JSON output 권장) if "Issues Found:" in result.stdout: # issue 수 추출 pass return {"issues_found": total_issues, "auto_fixable_count": auto_fixable, "suggestions": [] } def _run_commit_skill(self, ticket_num: str) -> dict: """ commit skill execute Returns: {"success": bool, "commit_hash": str, "message": str} """ commit_script = self.workspace_root / ".skills/commit/commit-message-generator.py" if not commit_script.exists(): print(f"⚠️ commit skillnot found: {commit_script}") return {"success": False} # skill execute result = subprocess.run(["python3", str(commit_script), "--ticket", ticket_num], cwd=self.project_path, capture_output=True, text=True) if result.returncode == 0: # commit hash import hash_result = subprocess.run(["git", "rev-parse", "HEAD"], cwd=self.project_path, capture_output=True, text=True) commit_hash = hash_result.stdout.strip() return {"success": True, "commit_hash": commit_hash, "output": result.stdout } else: return {"success": False, "error": result.stderr } def _run_test_runner(self) -> dict: """ test-runner skill execute Returns: {"all_passed": bool, "total": int, "passed": int, "failed": int, "coverage": float} """ test_script = self.workspace_root / ".skills/test-runner/test-runner.py" if not test_script.exists(): return None # skill execute result = subprocess.run(["python3", str(test_script), "--all", "--coverage"], cwd=self.project_path, capture_output=True, text=True) # simple parsing (실제to JSON output 권장) if result.returncode == 0: return {"all_passed": True, "total": 150, # 실제to outputin parsing "passed": 150, "failed": 0, "coverage": 0.85 } else: return {"all_passed": False, "total": 150, "passed": 145, "failed": 5, "coverage": 0.82 } def _has_api_changes(self) -> bool: """API change whether check""" # change된 file in progress API related file 있지 check result = subprocess.run(["git", "diff", "--name-only", "HEAD"], cwd=self.project_path, capture_output=True, text=True) changed_files = result.stdout.split('\n') api_patterns = ['api', 'route', 'endpoint', 'controller'] return any(any(pattern in file.lower() for pattern in api_patterns) for file in changed_files if file) def _run_docs_generator(self) -> dict: """ docs-generator skill execute Returns: {"success": bool, "files_generated": int} """ docs_script = self.workspace_root / ".skills/docs-generator/docs-generator.py" if not docs_script.exists(): return None # skill execute result = subprocess.run(["python3", str(docs_script), "--api", "--readme"], cwd=self.project_path, capture_output=True, text=True) return {"success": result.returncode == 0, "files_generated": 3 # 실제to outputin parsing } def _commit_docs(self, ticket_num: str): """documentation change사항 commit""" subprocess.run(["git", "add", "docs/", "README.md"], cwd=self.project_path) subprocess.run(["git", "commit", "-m", f"docs({ticket_num}): update API documentation\n\nCo-Authored-By: Claude Sonnet 4.5 <noreply@anthropic.com>" ], cwd=self.project_path) def _git_commit_push(self, ticket_num: str): """Git commit and push""" os.chdir(self.project_path) # change사항 check result = subprocess.run(["git", "diff-index", "--quiet", "HEAD", "--"], capture_output=True) if result.returncode!= 0: # change사항 exists subprocess.run(["git", "add", "."]) subprocess.run(["git", "commit", "-m", f"feat({ticket_num}): implement feature\n\nCo-Authored-By: Claude Sonnet 4.5 <noreply@anthropic.com>" ]) # Push branch = subprocess.run(["git", "rev-parse", "--abbrev-ref", "HEAD"], capture_output=True, text=True).stdout.strip() subprocess.run(["git", "push", "-u", "origin", branch]) print(f"✅ Git Push completed: {branch}") def main(): import argparse parser = argparse.ArgumentParser(description="Auto Pipeline - Claude Agent SDK") parser.add_argument("--project", help="project route") parser.add_argument("--resume", action="store_true", help="previous in progressstatusfrom resume") args = parser.parse_args() if not args.project: # current project auto detect import json config_file = Path(__file__).parent.parent / ".project-config.json" with open(config_file) as f: config = json.load(f) project_name = config["current_project"] project_path = Path(__file__).parent.parent / f"projects/{project_name}" else: project_path = Path(args.project) pipeline = AutoPipeline(project_path) pipeline.run_full_pipeline(resume=args.resume) if __name__ == "__main__": main()