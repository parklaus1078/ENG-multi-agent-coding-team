{"version": "0.0.1", "updated": "2026-03-19", "description": "PR review 체크list - 항목별 auto 검사 rule", "completeness": {"enabled": true, "checks": {"ticket_requirements": {"enabled": true, "severity": "error", "description": "ticket requirements all implementation" }, "no_todo_fixme": {"enabled": true, "severity": "warning", "patterns": ["TODO", "FIXME", "HACK", "XXX"], "description": "TODO/FIXME comment none" }, "error_handling": {"enabled": true, "severity": "error", "description": "all functionto error 핸들링" }, "tests_exist": {"enabled": true, "severity": "error", "min_coverage": 0.80, "description": "test 존재 and coverage 80% 상" } } }, "quality": {"enabled": true, "checks": {"function_length": {"enabled": true, "severity": "warning", "max_lines": 50, "description": "function 길 50줄 하" }, "complexity": {"enabled": true, "severity": "warning", "max_complexity": 10, "description": "순환 복잡도 10 하" }, "duplicate_code": {"enabled": true, "severity": "warning", "min_duplicate_lines": 6, "description": "in progress복 code none" }, "naming": {"enabled": true, "severity": "warning", "patterns": {"camelCase": "^[a-z][a-zA-Z0-9]*$", "PascalCase": "^[A-Z][a-zA-Z0-9]*$", "CONSTANT": "^[A-Z][A-Z0-9_]*$" }, "description": "명확한 네밍" }, "magic_numbers": {"enabled": true, "severity": "warning", "allowed": [0, 1, -1], "description": "매직 넘버 none" } } }, "security": {"enabled": true, "checks": {"hardcoded_secrets": {"enabled": true, "severity": "error", "patterns": ["(password|passwd|pwd)\\s*=\\s*['\"]", "(api_key|apikey|api-key)\\s*=\\s*['\"]", "(secret|token)\\s*=\\s*['\"]", "sk-[a-zA-Z0-9]{32,}", "ghp_[a-zA-Z0-9]{36}" ], "description": "하드코딩된 password/API 키 none" }, "sql_injection": {"enabled": true, "severity": "error", "patterns": ["execute\\(.*\\+.*\\)", "query\\(.*\\+.*\\)", "SELECT.*\\+.*FROM" ], "description": "SQL Injection 방어" }, "xss": {"enabled": true, "severity": "error", "patterns": ["innerHTML\\s*=", "dangerouslySetInnerHTML", "document.write\\(" ], "description": "XSS 방어" }, "input_validation": {"enabled": true, "severity": "warning", "description": "user input validation" } } }, "style": {"enabled": true, "checks": {"linter": {"enabled": true, "severity": "warning", "tools": {"javascript": "eslint", "typescript": "eslint", "python": "pylint", "go": "golint" }, "description": "Linter passed" }, "formatting": {"enabled": true, "severity": "warning", "description": "일관된 포맷팅" }, "commented_code": {"enabled": true, "severity": "warning", "description": "comment process된 code none" } } }, "performance": {"enabled": true, "checks": {"n_plus_one": {"enabled": true, "severity": "warning", "patterns": ["for.*\\n.*query\\(", "for.*\\n.*find\\(", "for.*\\n.*get\\(" ], "description": "N+1 쿼리 none" }, "inefficient_loops": {"enabled": true, "severity": "warning", "description": "비효율적 반복문 none" }, "async_usage": {"enabled": true, "severity": "info", "description": "Async/await 적절히 사용" } } }, "documentation": {"enabled": true, "checks": {"docstrings": {"enabled": true, "severity": "warning", "required_for": ["public_functions", "classes"], "description": "public APIto docstring" }, "changelog": {"enabled": false, "severity": "info", "description": "CHANGELOG update" }, "readme": {"enabled": true, "severity": "info", "when": "api_changes", "description": "README update (API change when)" } } }, "pr_constraints": {"max_lines_changed": 500, "max_files_changed": 20, "require_description": true, "require_ticket_reference": true, "block_without_tests": true, "min_coverage_delta": -5 }, "auto_fix_rules": {"enabled": true, "rules": [{"id": "replace_hardcoded_secrets", "pattern": "(password|api_key|secret)\\s*=\\s*['\"]([^'\"]+)['\"]", "replacement": "$1 = process.env.$1.toUpperCase()", "description": "하드코딩 password → environment variable" }, {"id": "sort_imports", "pattern": "import", "action": "sort_alphabetically", "description": "Import 알파벳 순 sort" }, {"id": "remove_trailing_spaces", "pattern": "\\s+$", "replacement": "", "description": "불required한 공백 remove" }, {"id": "remove_commented_code", "pattern": "^\\s*//.*\\w+.*=.*$", "replacement": "", "description": "comment process된 code delete" } ] } }